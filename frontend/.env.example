VITE_API_BASE_URL=/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# backend | gradio
VITE_REPORT_API_MODE=backend

# Gradio classifier endpoint.
# When this is set, complaint uploads will attach the Gradio prediction so the saved complaint
# uses the hosted classifier result instead of silently reclassifying with the local model.
VITE_GRADIO_API_URL=https://4dcf97b9438c1f4ced.gradio.live/

# In gradio mode, also save complaint to backend database for dashboards
VITE_GRADIO_SAVE_TO_BACKEND=true
